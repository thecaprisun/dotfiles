{
  "layer": "top",
    "modules-left": ["hyprland/workspaces"],
    "modules-center": [],
    "modules-right": ["backlight", "pulseaudio", "battery"],
    "custom/arch": {
      "format": " ΎΝΔ ",
      "tooltip": false,
      "on-click": "sh wofi --show drun"
    },
    "hyprland/workspaces": {
      "format": "{name}",
      "format": "{icon}",
      "tooltip": false,
      "all-outputs": true,
      "format-icons": {
        "active": "ΎΗΤ",
        "default": "ΎΕΝ"
      }
    },
    "clock": {
      "format": "<span color='#b4befe'>ΎΑΩ </span>{:%H:%M}",
    },
    "backlight": {
      "device": "intel_backlight",
      "format": "<span color='#b4befe'>{icon}</span> {percent}%",
      "format-icons": ["ΌΟΞ", "ΌΠΥ", "ΌΠΣ", "ΌΠΠ", "ΌΠΟ", "ΌΠΞ", "ΌΠΛ", "ΌΠΙ", "ΌΟδ"]
    },
    "pulseaudio": {
      "format": "<span color='#b4befe'>{icon}</span> {volume}%",
      "format-muted": "ΎΑο ",
      "tooltip": false,
      "format-icons": {
        "headphone": "ΎΑξ",
        "default": ["ΎΑο ", "ΎΑπ ", "≤░Χ╛ ", "≤░Χ╛ ", "≤░Χ╛ ", "ΎΑρ ", "ΎΑρ ", "ΎΑρ "]
      },
      "scroll-step": 1,
    },
    "bluetooth": {
      "format": "<span color='#b4befe'>ΎΛΦ</span> {status}",
      "format-disabled": "", // an empty format will hide the module
      "format-connected": "<span color='#b4befe'>ΎΛΦ</span> {num_connections}",
      "tooltip-format": "{device_enumerate}",
      "tooltip-format-enumerate-connected": "{device_alias}   {device_address}"
    },
    "network": {
      "interface": "wlo1",
      "format": "{ifname}",
      "format-wifi": "<span color='#b4befe'>ΎΘτ  </span>{essid}",
      "format-ethernet": "{ipaddr}/{cidr} ΎηΨ",
      "format-disconnected": "<span color='#b4befe'>≤░Ψς  </span>No Network",
      "tooltip": false,
    },
    "battery": {
      "format": "<span color='#b4befe'>{icon}</span> {capacity}%",
      "format-icons": ["≤░Β║", "≤░Β╝", "≤░Β╜", "≤░Β╜", "≤░Β┐", "≤░ΓΑ", "≤░ΓΑ", "≤░ΓΒ", "≤░ΓΒ", "≤░Β╣"],
      "format-charging": "<span color='#b4befe'>≤░ΓΕ</span> {capacity}%",
      "tooltip": false,
    },
}
